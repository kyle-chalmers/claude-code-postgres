# Optional. Copy to .env to override the local demo settings. None of this is a real
# secret -- the demo Postgres is a disposable local container.

# Admin password for the local Docker Postgres (read by docker-compose.yml).
POSTGRES_PASSWORD=demo

# Connection coordinates for psql / libpq (handy to `source` or export).
PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGDATABASE=postgres

# Read-only login you hand the agent. Set the password you chose in
# sql/02_create_readonly_role.sql, and prefer ~/.pgpass so it never lands in
# shell history (see the README, step 4).
ANALYST_RO_USER=analyst_ro

# --- Cloud Postgres (alternative to the local Docker DB above) ---
# Point these at a managed provider instead: Neon, Supabase, Amazon RDS/Aurora,
# Google Cloud SQL, Azure Database for PostgreSQL, Render, Railway. SSL is
# required on managed providers. Keep the analyst_ro password in ~/.pgpass
# (chmod 0600) with the provider host on the line, not here.
# PGHOST=<endpoint>.<region>.aws.neon.tech
# PGPORT=5432
# PGDATABASE=<your-db>
# PGSSLMODE=require
