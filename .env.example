# Copy to .env and adjust if needed. These point psql/libpq at the local demo DB.
# No real secrets live here -- the demo password is a throwaway.

# Admin connection (used to create the read-only role and load the schema)
PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGDATABASE=postgres
# PGPASSWORD=demo        # prefer ~/.pgpass (chmod 0600) over putting this in the environment

# Read-only connection (what you hand the agent). Set the password you chose in
# sql/02_create_readonly_role.sql. Prefer ~/.pgpass so it never lands in shell history.
ANALYST_RO_USER=analyst_ro
